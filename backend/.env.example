# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=faceattend
DB_USER=root
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=8h

# Late threshold (minutes after midnight)
LATE_THRESHOLD_MINUTES=495

# Upload path
UPLOAD_DIR=./uploads/faces
